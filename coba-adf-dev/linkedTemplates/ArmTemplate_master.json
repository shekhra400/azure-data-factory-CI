{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "coba-adf-dev"
		},
		"blob-storage-linked-service_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'blob-storage-linked-service'"
		},
		"keyvault-linked-service_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://coba-kv-dev.vault.azure.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "coba-adf-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"blob-storage-linked-service_connectionString": {
						"value": "[parameters('blob-storage-linked-service_connectionString')]"
					},
					"keyvault-linked-service_properties_typeProperties_baseUrl": {
						"value": "[parameters('keyvault-linked-service_properties_typeProperties_baseUrl')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}